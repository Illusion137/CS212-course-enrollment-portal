<div class="catalog-outer">
	<div class="catalog-panel bg-light bg-gradient rounded">
		<input type="text" id="search-input" placeholder="Search" class="form-control" />
		<div class="d-flex flex-column flex-md-row gap-2 mt-2">
			<div class="dropdown">
				<button id="subject-btn" class="btn btn-secondary dropdown-toggle catalog-filter-btn btn-lightish" type="button" data-bs-toggle="dropdown" aria-expanded="false">Select Subject</button>
				<ul id="subject-dropdown-list" class="dropdown-menu" style="max-height: 300px; overflow-y: auto"></ul>
			</div>
			<div class="dropdown">
				<button id="course-nbr-btn" class="btn btn-secondary dropdown-toggle catalog-filter-btn" type="button" data-bs-toggle="dropdown" aria-expanded="false" disabled>Select Course</button>
				<ul id="course-nbr-dropdown-list" class="dropdown-menu" style="max-height: 300px; overflow-y: auto"></ul>
			</div>
		</div>
		<div class="d-flex flex-column flex-md-row flex-wrap gap-2 mt-2">
			<div class="dropdown">
				<button id="status-btn" class="btn btn-secondary dropdown-toggle catalog-filter-btn btn-lightish" type="button" data-bs-toggle="dropdown" aria-expanded="false">Status</button>
				<ul id="status-dropdown-list" class="dropdown-menu"></ul>
			</div>
			<div class="dropdown">
				<button id="level-btn" class="btn btn-secondary dropdown-toggle catalog-filter-btn btn-lightish" type="button" data-bs-toggle="dropdown" aria-expanded="false">Level</button>
				<ul id="level-dropdown-list" class="dropdown-menu"></ul>
			</div>
			<div class="dropdown">
				<button id="credits-btn" class="btn btn-secondary dropdown-toggle catalog-filter-btn btn-lightish" type="button" data-bs-toggle="dropdown" aria-expanded="false">Credits</button>
				<ul id="credits-dropdown-list" class="dropdown-menu" style="max-height: 300px; overflow-y: auto"></ul>
			</div>
			<input type="text" id="instructor-input" placeholder="Instructor" class="form-control catalog-instructor-input" />
		</div>
	</div>
	<div id="course-list" class="mt-4">
		<p class="text-muted">No courses to display.</p>
	</div>
	<button id="load-more-btn" class="btn btn-outline-secondary w-100 mt-3" style="display: none">Load More</button>
</div>
<script src="/js/catalog.js"></script>
