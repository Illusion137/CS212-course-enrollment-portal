<div class="d-flex" style="height: calc(100vh - 70px)">
	<div class="pt-4 pb-4 flex-grow-1" style="height: calc(100vh - 70px); overflow-y: auto">
		<div class="px-4">
			<div class="d-flex gap-4 mb-3">
				<div class="form-check">
					<input class="form-check-input" type="checkbox" id="show-enrolled" checked />
					<label class="form-check-label" for="show-enrolled">Enrolled Courses</label>
				</div>
				<div class="form-check">
					<input class="form-check-input" type="checkbox" id="show-waitlisted" />
					<label class="form-check-label" for="show-waitlisted">Waitlisted Courses</label>
				</div>
			</div>
			<div id="course-list">
				<p class="text-muted">Loading courses...</p>
			</div>
		</div>
	</div>
	<div class="border-left pt-4 pb-4 d-flex flex-column gap-4 flex-shrink-0" style="overflow-y: auto; height: calc(100vh - 70px)">
		<%- include('../partials/schedule_view') %> <%- include('../partials/course_map') %>
	</div>
</div>
<script src="/js/view_courses.js"></script>
