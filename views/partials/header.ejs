<%
const navLinks = [
	{ href: '/', label: 'Catalog' },
	{ href: '/view-courses', label: 'View Courses' },
	{ href: '/manage-courses', label: 'Manage Courses' },
	{ href: '/notifications', label: 'Notifications' },
];
%>
<nav class="navbar navbar-expand-lg bg-white shadow-sm">
	<div class="container-fluid">
		<a class="navbar-brand fw-semibold d-none d-lg-block" href="/">NAPI Course Portal</a>
		<button
			class="navbar-toggler border-0 shadow-none"
			type="button"
			data-bs-toggle="collapse"
			data-bs-target="#navbarNav"
			aria-controls="navbarNav"
			aria-expanded="false"
			aria-label="Toggle navigation"
		>
			<span class="navbar-toggler-icon"></span>
		</button>
		<div class="collapse navbar-collapse" id="navbarNav">
			<div class="navbar-nav ms-auto gap-1">
				<% navLinks.forEach(link => { %>
				<a class="nav-link <%= typeof title !== 'undefined' && title === link.label ? 'text-dark fw-semibold' : 'text-secondary' %>"
					<%= typeof title !== 'undefined' && title === link.label ? 'aria-current="page"' : '' %>
					href="<%= link.href %>"><%= link.label %></a>
				<% }) %>
			</div>
		</div>
	</div>
</nav>
