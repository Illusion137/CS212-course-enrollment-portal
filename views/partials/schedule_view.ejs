<link rel="stylesheet" href="/css/schedule_view.css" />
<div id="schedule-view-component" class="w-100 card shadow-sm schedule-card mb-0" style="min-height: 50vh; overflow-y: auto">
	<div class="schedule-header-bar rounded-top">Weekly Schedule</div>
	<div class="schedule-body-wrap">
		<div class="schedule-inner">
			<div class="schedule-time-col">
				<div class="schedule-time-spacer"></div>
				<div class="schedule-time-grid">
					<!-- from 8am to 9pm -->
					<% for (let hour = 8; hour <= 21; hour++) { %>
					<div class="schedule-time-label" style="top: <%= (hour - 8) * 60 %>px"><%= hour < 12 ? hour + ':00 AM' : hour === 12 ? '12:00 PM' : (hour - 12) + ':00 PM' %></div>
					<% } %>
				</div>
			</div>
			<div class="schedule-days">
				<% ['Mon','Tue','Wed','Thu','Fri'].forEach(function(day) { %>
				<div class="schedule-day-col">
					<div class="schedule-day-header"><%= day %></div>
					<div class="schedule-day-body" data-day="<%= day %>">
						<% for (let hour = 0; hour <= 13; hour++) { %>
						<div class="schedule-hour-line" style="top: <%= hour * 60 %>px"></div>
						<% if (hour < 13) { %>
						<div class="schedule-half-line" style="top: <%= hour * 60 + 30 %>px"></div>
						<% } %> <% } %>
					</div>
				</div>
				<% }); %>
			</div>
		</div>
	</div>
</div>
<script src="/js/schedule_view.js"></script>
